@page "/apps/{AppId:guid}/edit/{EnvSegment}"
@page "/apps/{AppId:guid}/edit/{EnvSegment}/{Kind?}"
@rendermode InteractiveServer
@attribute [Authorize(Roles = $"{IdentityRoleNames.Administrator},{IdentityRoleNames.Member}")]

@using System.Security.Claims
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.EntityFrameworkCore
@using S3EnvManager.Database
@using S3EnvManager.Database.Models
@using S3EnvManager.Sops
@using S3EnvManager.Web.Services
@using AppEntity = S3EnvManager.Database.Models.App

@inject ApplicationDbContext Db
@inject ISecretBundleService SecretBundleService
@inject ICmkRegistryService CmkRegistryService
@inject NavigationManager NavigationManager
@inject IDialogService DialogService
@inject IJSRuntime JsRuntime
@inject ISnackbar Snackbar

<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<PageTitle>시크릿 편집</PageTitle>

@if (_app is null || _env is null)
{
	<MudProgressCircular Color="Color.Default" Indeterminate="true" />
}
else
{
	<MudText Typo="Typo.h4" Class="mb-4">
		@_app.Name / @_env.Name.ToObjectSegment() @(_kind == SecretBundleKind.Overwrite ? "(overwrite)" : "")
	</MudText>

	@if (_kind == SecretBundleKind.Overwrite)
	{
		<MudAlert Severity="Severity.Warning" Class="mb-4">
			overwrite 번들은 로컬 env var보다도 우선하는 최종 강제 override다 -
			여기 채운 키는 Application의 다른 어떤 설정이든 최후에 덮어쓴다. 대부분의 환경에서는
			비워 둔다.
		</MudAlert>
	}

	@if (_adminCmkMissing)
	{
		<MudAlert Severity="Severity.Warning" Class="mb-4">
			Admin role의 활성 CMK가 아직 등록되어 있지 않아 저장할 수 없습니다 -
			<MudLink Href="admin/cmk-registry">CMK 레지스트리</MudLink> 화면에서 먼저 등록하세요.
		</MudAlert>
	}

	@if (_autoAppliedTheirsKeys.Count > 0)
	{
		<MudAlert Severity="Severity.Info" Class="mb-4">
			다른 사용자가 바꾼 @(_autoAppliedTheirsKeys.Count)개 키가 자동으로 반영되었습니다: @string.Join(", ", _autoAppliedTheirsKeys)
		</MudAlert>
	}

	@if (_errorMessage is not null)
	{
		<MudAlert Severity="Severity.Error" Class="mb-4">@_errorMessage</MudAlert>
	}

	@if (_conflicts.Count > 0)
	{
		<MudAlert Severity="Severity.Warning" Class="mb-4">
			다른 사용자와 같은 키를 다른 값으로 바꿔 충돌했습니다. 각 키마다 사용할 값을 고른 뒤 "충돌 해결하고 다시 저장"을 눌러주세요.
		</MudAlert>
		<MudPaper Class="pa-4 mb-4">
			@foreach (var conflict in _conflicts)
			{
				<MudText Typo="Typo.subtitle1" Class="mt-2">@conflict.Key</MudText>
				<MudRadioGroup T="bool" @bind-Value="_conflictUseMine[conflict.Key]">
					<MudRadio T="bool" Value="true">
						<MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
							<MudText>내 값:</MudText>
							<SecretValuePreview Value="@(conflict.Mine ?? string.Empty)" ReadOnly="true" />
						</MudStack>
					</MudRadio>
					<MudRadio T="bool" Value="false">
						<MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
							<MudText>상대 값:</MudText>
							<SecretValuePreview Value="@(conflict.Theirs ?? string.Empty)" ReadOnly="true" />
						</MudStack>
					</MudRadio>
				</MudRadioGroup>
			}
			<MudButton Variant="Variant.Filled"
				Color="Color.Warning"
				Class="mt-2"
				OnClick="ResolveConflictsAndRetryAsync"
				Disabled="_adminCmkMissing">
				충돌 해결하고 다시 저장
			</MudButton>
		</MudPaper>
	}
	else if (_advancedMode)
	{
		<MudText Typo="Typo.body2" Class="mb-2">
			모든 키=값을 텍스트로 한 번에 편집합니다. 값에 포함된 개행/백슬래시는
			\n / \\ 로 이스케이프되어 표시됩니다 - 그대로 두고 편집하세요.
		</MudText>
		<MudTextField T="string" @bind-Value="_advancedText" Lines="20" Variant="Variant.Outlined"
			Style="font-family: monospace;" Immediate="true" />
		@if (_advancedError is not null)
		{
			<MudAlert Severity="Severity.Error" Class="mt-2">@_advancedError</MudAlert>
		}
		<MudStack Row="true" Class="mt-4" Spacing="2">
			<MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="ApplyAdvancedEdit">적용</MudButton>
			<MudButton Variant="Variant.Outlined" OnClick="CancelAdvancedEdit">취소</MudButton>
		</MudStack>
	}
	else
	{
		<MudTable Items="_rows" Hover="true" Elevation="0">
			<HeaderContent>
				<MudTh>키</MudTh>
				<MudTh>값</MudTh>
				<MudTh></MudTh>
			</HeaderContent>
			<RowTemplate>
				<MudTd DataLabel="키">
					<MudTextField @bind-Value="context.Key" Immediate="true"
						Validation="@(new Func<string, string?>(SecretKeyNameValidator.Validate))" />
				</MudTd>
				<MudTd DataLabel="값"><SecretValuePreview @bind-Value="context.Value" /></MudTd>
				<MudTd>
					<MudIconButton Icon="@Icons.Material.Filled.DeleteOutline" Color="Color.Error"
						OnClick="@(() => _rows.Remove(context))" title="이 키 삭제" />
				</MudTd>
			</RowTemplate>
		</MudTable>

		<MudStack Row="true" Class="mt-4" Spacing="2" AlignItems="AlignItems.Center" Wrap="Wrap.Wrap">
			<MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.Add"
				OnClick="@(() => _rows.Add(new KeyValueRow()))">
				키 추가
			</MudButton>
			<MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveAsync"
				Disabled="_saving || _adminCmkMissing">
				@(_saving ? "저장 중..." : "저장")
			</MudButton>
			<MudButton Variant="Variant.Outlined"
				StartIcon="@Icons.Material.Filled.History"
				OnClick="OpenHistoryAsync">
				히스토리
			</MudButton>
			<MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.Edit" OnClick="EnterAdvancedMode">
				고급 편집
			</MudButton>
			<MudButton Variant="Variant.Outlined"
				StartIcon="@Icons.Material.Filled.ContentCopy"
				OnClick="CopyAllAsync">
				전체 복사
			</MudButton>
			@if (_kind == SecretBundleKind.Overwrite)
			{
				<MudTooltip Text="base 번들 값에 이 overwrite(미저장 포함)를 겹쳐 최종 값을 미리 봅니다. 로컬 env var는 서버가 알 수 없어 반영되지 않습니다.">
					<MudButton Variant="Variant.Outlined"
						StartIcon="@Icons.Material.Filled.Layers"
						OnClick="ViewEffectiveAsync">
						병합 결과 보기
					</MudButton>
				</MudTooltip>
			}
			@if (GetChangedKeyCount() is > 0 and var changedKeyCount)
			{
				<MudText Typo="Typo.body2" Color="Color.Warning">저장되지 않은 변경 @(changedKeyCount)건</MudText>
			}
		</MudStack>
	}
}

@code {
	[Parameter] public Guid AppId { get; set; }
	[Parameter] public string EnvSegment { get; set; } = string.Empty;
	[Parameter] public string? Kind { get; set; }

	[CascadingParameter] private Task<AuthenticationState>? AuthenticationStateTask { get; set; }

	private SecretBundleKind _kind;

	private async Task<string?> GetCurrentUserIdAsync()
	{
		if (AuthenticationStateTask is null)
		{
			return null;
		}
		var state = await AuthenticationStateTask;
		return state.User.FindFirstValue(ClaimTypes.NameIdentifier);
	}

	private async Task<string?> GetCurrentUserEmailAsync()
	{
		if (AuthenticationStateTask is null)
		{
			return null;
		}
		var state = await AuthenticationStateTask;
		return state.User.FindFirstValue(ClaimTypes.Email);
	}

	private AppEntity? _app;
	private Env? _env;
	private readonly List<KeyValueRow> _rows = [];
	private Dictionary<string, string> _baseSnapshot = [];
	private string? _baseETag;
	private bool _saving;
	private bool _adminCmkMissing;
	private string? _errorMessage;
	private List<string> _autoAppliedTheirsKeys = [];
	private List<ConflictItem> _conflicts = [];
	private Dictionary<string, bool> _conflictUseMine = [];
	private Dictionary<string, string> _pendingMergedValues = [];
	private bool _advancedMode;
	private string _advancedText = string.Empty;
	private string? _advancedError;

	protected override async Task OnInitializedAsync()
	{
		_kind = string.Equals(Kind, "overwrite", StringComparison.OrdinalIgnoreCase)
			? SecretBundleKind.Overwrite
			: SecretBundleKind.Base;
		_app = await Db.Apps.AsNoTracking().SingleAsync(a => a.Id == AppId);
		var envName = ParseEnvSegment(EnvSegment);
		_env = await Db.Envs.AsNoTracking().SingleAsync(e => e.AppId == AppId && e.Name == envName);

		var session = await SecretBundleService.LoadForEditAsync(_env.Id, _kind);
		LoadSessionIntoState(session.Values, session.BaseETag);

		var registrations = await CmkRegistryService.ListAsync();
		_adminCmkMissing = !registrations.Any(r => r.Role == CmkRole.Admin && r.Status == CmkStatus.Active);
	}

	private void LoadSessionIntoState(IReadOnlyDictionary<string, string> values, string? etag)
	{
		_baseSnapshot = new Dictionary<string, string>(values);
		_baseETag = etag;
		_rows.Clear();
		foreach (var (key, value) in values)
		{
			_rows.Add(new KeyValueRow { Key = key, Value = value });
		}
	}

	private async Task SaveAsync()
	{
		_errorMessage = null;
		if (!TryBuildEditedValues(out var editedValues, out var validationError))
		{
			_errorMessage = validationError;
			return;
		}

		_saving = true;
		try
		{
			var actorUserId = await GetCurrentUserIdAsync();
			var actorEmail = await GetCurrentUserEmailAsync();
			await ApplyOutcomeAsync(
				await SecretBundleService.SaveAsync(
					_env!.Id, _baseSnapshot, _baseETag, editedValues, actorUserId, actorEmail, _kind),
				actorUserId, actorEmail);
		}
		catch (InvalidOperationException)
		{
			_adminCmkMissing = true;
			_errorMessage = "Admin role의 활성 CMK가 등록되어 있지 않아 저장에 실패했습니다 - 위 안내에서 CMK 레지스트리로 이동해 먼저 등록하세요.";
		}
		catch (Exception ex)
		{
			_errorMessage = $"저장에 실패했습니다: {ex.Message}";
		}
		finally
		{
			_saving = false;
		}
	}

	private async Task ResolveConflictsAndRetryAsync()
	{
		var finalValues = new Dictionary<string, string>(_pendingMergedValues);
		foreach (var conflict in _conflicts)
		{
			var useMine = !_conflictUseMine.TryGetValue(conflict.Key, out var value) || value;
			finalValues[conflict.Key] = (useMine ? conflict.Mine : conflict.Theirs)!;
		}

		_saving = true;
		try
		{
			var actorUserId = await GetCurrentUserIdAsync();
			var actorEmail = await GetCurrentUserEmailAsync();
			await ApplyOutcomeAsync(
				await SecretBundleService.SaveAsync(
					_env!.Id, _baseSnapshot, _baseETag, finalValues, actorUserId, actorEmail, _kind),
				actorUserId, actorEmail);
		}
		catch (InvalidOperationException)
		{
			_adminCmkMissing = true;
			_errorMessage = "Admin role의 활성 CMK가 등록되어 있지 않아 저장에 실패했습니다 - 위 안내에서 CMK 레지스트리로 이동해 먼저 등록하세요.";
		}
		catch (Exception ex)
		{
			_errorMessage = $"저장에 실패했습니다: {ex.Message}";
		}
		finally
		{
			_saving = false;
		}
	}

	private async Task ApplyOutcomeAsync(SaveOutcome outcome, string? actorUserId, string? actorEmail)
	{
		switch (outcome)
		{
			case SaveSuccess success:
				_conflicts = [];
				_conflictUseMine = [];
				_autoAppliedTheirsKeys = [];
				LoadSessionIntoState(
					_rows.Where(r => r.Key.Length > 0).ToDictionary(r => r.Key, r => r.Value), success.NewETag);
				Snackbar.Add("저장했습니다.", Severity.Success);
				break;

			case SaveConflict conflict:
				_autoAppliedTheirsKeys = conflict.AutoAppliedTheirsKeys.ToList();
				_baseSnapshot = new Dictionary<string, string>(conflict.TheirsSnapshot);
				_baseETag = conflict.TheirsETag;
				_pendingMergedValues = new Dictionary<string, string>(conflict.MergedValues);

				if (conflict.RealConflicts.Count == 0)
				{
					await ApplyOutcomeAsync(
						await SecretBundleService.SaveAsync(
							_env!.Id, _baseSnapshot, _baseETag, _pendingMergedValues, actorUserId, actorEmail, _kind),
						actorUserId, actorEmail);
					return;
				}

				_conflicts = conflict.RealConflicts.ToList();
				_conflictUseMine = _conflicts.ToDictionary(c => c.Key, _ => true);
				break;

			case SaveFailed failed:
				_errorMessage = failed.Reason;
				break;
		}
	}

	private Int32 GetChangedKeyCount()
	{
		// 키 중복 시 ToDictionary는 예외를 던지므로(편집 중 일시적으로 겹칠 수 있음), 여기서는
		// 마지막 값으로 덮어써 렌더가 죽지 않게만 한다 - 중복 검증은 "저장" 시 따로 한다.
		var current = new Dictionary<string, string>();
		foreach (var row in _rows.Where(r => r.Key.Length > 0))
		{
			current[row.Key] = row.Value;
		}
		var changed = 0;
		foreach (var key in current.Keys.Union(_baseSnapshot.Keys))
		{
			var hasCurrent = current.TryGetValue(key, out var currentValue);
			var hasBase = _baseSnapshot.TryGetValue(key, out var baseValue);
			if (hasCurrent != hasBase || currentValue != baseValue)
			{
				changed++;
			}
		}
		return changed;
	}

	private bool TryBuildEditedValues(out Dictionary<string, string> values, out string? error)
	{
		values = [];
		var trimmedRows = _rows.Where(r => r.Key.Length > 0).ToList();
		var duplicateKey = trimmedRows.GroupBy(r => r.Key).FirstOrDefault(g => g.Count() > 1)?.Key;
		if (duplicateKey is not null)
		{
			error = $"키 '{duplicateKey}'가 중복되었습니다.";
			return false;
		}

		foreach (var row in trimmedRows)
		{
			values[row.Key] = row.Value;
		}
		error = null;
		return true;
	}

	private void EnterAdvancedMode()
	{
		_advancedText = SecretBundleTextFormat.Format(CurrentRowsAsPairs());
		_advancedError = null;
		_advancedMode = true;
	}

	private void ApplyAdvancedEdit()
	{
		if (!SecretBundleTextFormat.TryParse(_advancedText, out var values, out var error))
		{
			_advancedError = error;
			return;
		}

		_rows.Clear();
		foreach (var (key, value) in values)
		{
			_rows.Add(new KeyValueRow { Key = key, Value = value });
		}
		_advancedError = null;
		_advancedMode = false;
		Snackbar.Add("고급 편집 내용을 반영했습니다 - '저장'을 눌러야 실제로 저장됩니다.", Severity.Info);
	}

	private void CancelAdvancedEdit()
	{
		_advancedMode = false;
		_advancedError = null;
	}

	private async Task CopyAllAsync()
	{
		var text = SecretBundleTextFormat.Format(CurrentRowsAsPairs());
		await JsRuntime.InvokeVoidAsync("navigator.clipboard.writeText", text);
		Snackbar.Add("전체 항목을 클립보드에 복사했습니다.", Severity.Success);
	}

	private IEnumerable<KeyValuePair<string, string>> CurrentRowsAsPairs() =>
		_rows.Where(r => r.Key.Length > 0).Select(r => new KeyValuePair<string, string>(r.Key, r.Value));

	private async Task ViewEffectiveAsync()
	{
		var baseSession = await SecretBundleService.LoadForEditAsync(_env!.Id, SecretBundleKind.Base);
		var overwriteValues = CurrentRowsAsPairs().ToDictionary(kv => kv.Key, kv => kv.Value);
		var merged = EffectiveSecretMerge.Merge(baseSession.Values, overwriteValues)
			.OrderBy(kv => kv.Key, StringComparer.Ordinal);

		var parameters = new DialogParameters<SecretValueEditDialog>
		{
			{ x => x.Value, SecretBundleTextFormat.Format(merged) },
			{ x => x.ReadOnly, true },
		};
		await DialogService.ShowAsync<SecretValueEditDialog>("base + overwrite 병합 결과 (로컬 env var 제외)", parameters);
	}

	private async Task OpenHistoryAsync()
	{
		var parameters = new DialogParameters<SecretHistoryDialog>
		{
			{ x => x.EnvId, _env!.Id },
			{ x => x.Kind, _kind },
			{ x => x.SecretBundleService, SecretBundleService },
		};
		await DialogService.ShowAsync<SecretHistoryDialog>("저장 히스토리", parameters);
	}

	private static EnvName ParseEnvSegment(string segment) => segment switch
	{
		"dev" => EnvName.Dev,
		"staging" => EnvName.Staging,
		"product" => EnvName.Product,
		_ => throw new ArgumentOutOfRangeException(nameof(segment), segment, "알 수 없는 환경입니다."),
	};

	private sealed class KeyValueRow
	{
		public string Key { get; set; } = string.Empty;
		public string Value { get; set; } = string.Empty;
	}
}
