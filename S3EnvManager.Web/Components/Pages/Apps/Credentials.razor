@page "/apps/{AppId:guid}/credentials"
@rendermode InteractiveServer
@attribute [Authorize(Roles = $"{IdentityRoleNames.Administrator},{IdentityRoleNames.Member}")]

@using System.Security.Claims
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.EntityFrameworkCore
@using S3EnvManager.Database
@using S3EnvManager.Database.Models
@using S3EnvManager.Web.Services
@using AppEntity = S3EnvManager.Database.Models.App

@inject ApplicationDbContext Db
@inject IAppCredentialService AppCredentialService
@inject IJSRuntime JsRuntime
@inject ISnackbar Snackbar

<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<PageTitle>자격증명</PageTitle>

@if (_app is null)
{
	<MudProgressCircular Color="Color.Default" Indeterminate="true" />
}
else
{
	<MudBreadcrumbs Items="@(new List<BreadcrumbItem>
		{
			new("Apps", href: "apps"),
			new(_app.Name, href: null, disabled: true),
			new("자격증명", href: null, disabled: true),
		})" Class="pl-0 mb-2" />
	<MudText Typo="Typo.h4" Class="mb-4">@_app.Name 자격증명</MudText>

	@if (_errorMessage is not null)
	{
		<MudAlert Severity="Severity.Error" Class="mb-4">@_errorMessage</MudAlert>
	}

	@if (_revealedSecret is not null)
	{
		<MudAlert Severity="Severity.Warning" Class="mb-4">
			<MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
				<span>SecretAccessKey: <code>@_revealedSecret</code></span>
				<MudIconButton Icon="@Icons.Material.Filled.ContentCopy" Size="Size.Small"
					OnClick="@(() => CopyToClipboardAsync(_revealedSecret, "SecretAccessKey"))" title="SecretAccessKey 복사" />
			</MudStack>
		</MudAlert>
	}

	<MudButton Variant="Variant.Filled" Color="Color.Primary" Class="mb-4" OnClick="IssueAsync" Disabled="_busy">
		새 자격증명 발급
	</MudButton>

	@if (_credentials.Count == 0)
	{
		<MudText Typo="Typo.body1">발급된 자격증명이 없습니다 - 위 "새 자격증명 발급"으로 시작하세요.</MudText>
	}
	else
	{
		<MudTable Items="_credentials" Hover="true" Elevation="0">
			<HeaderContent>
				<MudTh>AccessKeyId</MudTh>
				<MudTh>발급일</MudTh>
				<MudTh>상태</MudTh>
				<MudTh></MudTh>
			</HeaderContent>
			<RowTemplate>
				<MudTd DataLabel="AccessKeyId">
					<MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
						<span>@context.AccessKeyId</span>
						<MudIconButton Icon="@Icons.Material.Filled.ContentCopy" Size="Size.Small"
							OnClick="@(() => CopyToClipboardAsync(context.AccessKeyId, "AccessKeyId"))" title="AccessKeyId 복사" />
					</MudStack>
				</MudTd>
				<MudTd DataLabel="발급일">@context.IssuedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</MudTd>
				<MudTd DataLabel="상태">
					@(context.RevokedAt is null
						? "활성"
						: $"폐기됨({context.RevokedAt.Value.ToLocalTime():yyyy-MM-dd HH:mm})")
				</MudTd>
				<MudTd>
					@if (context.RevokedAt is null)
					{
						<MudButton Size="Size.Small" Variant="Variant.Text" OnClick="@(() => RevealAsync(context.Id))">
							SecretAccessKey 보기
						</MudButton>
						<MudButton Size="Size.Small" Variant="Variant.Text" Color="Color.Error"
							OnClick="@(() => RevokeAsync(context.Id))">
							폐기
						</MudButton>
					}
				</MudTd>
			</RowTemplate>
		</MudTable>
	}
}

@code {
	[Parameter] public Guid AppId { get; set; }

	[CascadingParameter] private Task<AuthenticationState>? AuthenticationStateTask { get; set; }

	private async Task<string?> GetCurrentUserIdAsync()
	{
		if (AuthenticationStateTask is null)
		{
			return null;
		}
		var state = await AuthenticationStateTask;
		return state.User.FindFirstValue(ClaimTypes.NameIdentifier);
	}

	private AppEntity? _app;
	private List<AppCredential> _credentials = [];
	private bool _busy;
	private string? _errorMessage;
	private string? _revealedSecret;

	protected override async Task OnInitializedAsync()
	{
		_app = await Db.Apps.AsNoTracking().SingleAsync(a => a.Id == AppId);
		await ReloadAsync();
	}

	private async Task ReloadAsync()
	{
		_credentials = await AppCredentialService.ListAsync(AppId);
	}

	private async Task IssueAsync()
	{
		_errorMessage = null;
		_revealedSecret = null;
		_busy = true;
		try
		{
			var actorUserId = await GetCurrentUserIdAsync();
			var (_, secretAccessKey) = await AppCredentialService.IssueAsync(AppId, actorUserId);
			_revealedSecret = secretAccessKey;
			await ReloadAsync();
			Snackbar.Add("새 자격증명을 발급했습니다.", Severity.Success);
		}
		catch (Exception ex)
		{
			_errorMessage = $"발급에 실패했습니다: {ex.Message}";
		}
		finally
		{
			_busy = false;
		}
	}

	private async Task CopyToClipboardAsync(string value, string label)
	{
		await JsRuntime.InvokeVoidAsync("navigator.clipboard.writeText", value);
		Snackbar.Add($"{label}을(를) 클립보드에 복사했습니다.", Severity.Success);
	}

	private async Task RevealAsync(Guid credentialId)
	{
		_errorMessage = null;
		try
		{
			_revealedSecret = await AppCredentialService.RevealAsync(credentialId);
		}
		catch (Exception ex)
		{
			_errorMessage = $"조회에 실패했습니다: {ex.Message}";
		}
	}

	private async Task RevokeAsync(Guid credentialId)
	{
		_errorMessage = null;
		try
		{
			var actorUserId = await GetCurrentUserIdAsync();
			await AppCredentialService.RevokeAsync(credentialId, actorUserId);
			_revealedSecret = null;
			await ReloadAsync();
			Snackbar.Add("자격증명을 폐기했습니다.", Severity.Success);
		}
		catch (Exception ex)
		{
			_errorMessage = $"폐기에 실패했습니다: {ex.Message}";
		}
	}
}
