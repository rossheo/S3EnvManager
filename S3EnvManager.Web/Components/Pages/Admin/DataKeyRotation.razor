@page "/admin/data-key-rotation"
@rendermode InteractiveServer
@attribute [Authorize(Roles = IdentityRoleNames.Administrator)]

@using System.Security.Claims
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.EntityFrameworkCore
@using S3EnvManager.Database
@using S3EnvManager.Sops
@using S3EnvManager.Web.Services

@inject IDataKeyRotationSettingsService RotationSettingsService
@inject ApplicationDbContext Db
@inject IKmsKeyOperations Kms
@inject IAuditLogger AuditLogger
@inject IJSRuntime JsRuntime
@inject ISnackbar Snackbar

<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<PageTitle>데이터 키 로테이션</PageTitle>

<MudText Typo="Typo.h4" Class="mb-2">데이터 키 로테이션</MudText>
<MudText Typo="Typo.body2" Class="mb-1">발급된 App 자격증명의 SecretKey를 암호화하는 데이터 키를 이 주기마다 새로 발급합니다.</MudText>
<MudText Typo="Typo.body2" Class="mb-4">
	이미 저장된 값은 즉시 재암호화하지 않고 각자 자기 세대로 계속 복호화됩니다 - 새로
	발급/변경되는 값만 최신 세대를 씁니다.
</MudText>

@if (_currentDays is null)
{
	<MudProgressCircular Color="Color.Default" Indeterminate="true" />
}
else
{
	<MudPaper Class="pa-4 mb-4" MaxWidth="500px" Style="width: 100%;">
		<MudNumericField @bind-Value="_editingDays" Label="로테이션 주기(일)" Min="1" Max="3650" Immediate="true" />
		<MudButton Class="mt-4" Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveAsync">저장</MudButton>
	</MudPaper>

	<MudPaper Class="pa-4" MaxWidth="500px" Style="width: 100%;">
		<MudText Typo="Typo.subtitle1" Class="mb-2">현재 상태</MudText>
		<MudStack Row="true" Justify="Justify.SpaceBetween" Class="py-1">
			<MudText Typo="Typo.body2">발급된 데이터 키 세대 수</MudText>
			<MudText Typo="Typo.body2" Style="font-weight: 500;">@_generationCount</MudText>
		</MudStack>
		<MudStack Row="true" Justify="Justify.SpaceBetween" Class="py-1">
			<MudText Typo="Typo.body2">최신 세대 발급 시각</MudText>
			<MudText Typo="Typo.body2" Style="font-weight: 500;">
				@(_latestGenerationAt is null
					? "-"
					: _latestGenerationAt.Value.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss"))
			</MudText>
		</MudStack>
		<MudButton Class="mt-4" Variant="Variant.Filled" Color="Color.Secondary"
			OnClick="RotateNowAsync" Disabled="_rotating">
			지금 로테이션
		</MudButton>
	</MudPaper>
}

@code {
	[CascadingParameter] private Task<AuthenticationState>? AuthenticationStateTask { get; set; }

	private Int32? _currentDays;
	private Int32 _editingDays;
	private Int32 _generationCount;
	private DateTimeOffset? _latestGenerationAt;
	private bool _rotating;

	protected override async Task OnInitializedAsync()
	{
		await ReloadAsync();
	}

	private async Task ReloadAsync()
	{
		_currentDays = await RotationSettingsService.GetIntervalDaysAsync();
		_editingDays = _currentDays.Value;
		_generationCount = await Db.DataKeyGenerations.CountAsync();
		_latestGenerationAt = await Db.DataKeyGenerations.AsNoTracking()
			.OrderByDescending(d => d.CreatedAt)
			.Select(d => (DateTimeOffset?)d.CreatedAt)
			.FirstOrDefaultAsync();
	}

	private async Task<string?> GetCurrentUserIdAsync()
	{
		if (AuthenticationStateTask is null)
		{
			return null;
		}
		var state = await AuthenticationStateTask;
		return state.User.FindFirstValue(ClaimTypes.NameIdentifier);
	}

	private async Task SaveAsync()
	{
		try
		{
			var actorUserId = await GetCurrentUserIdAsync();
			await RotationSettingsService.SetIntervalDaysAsync(_editingDays, actorUserId);
			await ReloadAsync();
			Snackbar.Add("로테이션 주기를 저장했습니다.", Severity.Success);
		}
		catch (Exception ex)
		{
			Snackbar.Add($"저장에 실패했습니다: {ex.Message}", Severity.Error);
		}
	}

	private async Task RotateNowAsync()
	{
		var confirmed = await JsRuntime.InvokeAsync<bool>(
			"confirm", "지금 새 데이터 키 세대를 발급할까요? 이후 새로 발급/변경되는 값부터 이 세대를 씁니다.");
		if (!confirmed)
		{
			return;
		}

		_rotating = true;
		try
		{
			var actorUserId = await GetCurrentUserIdAsync();
			var outcome = await DataKeyRotationService.RotateNowAsync(
				Db, Kms, AuditLogger, TimeProvider.System, actorUserId);
			await ReloadAsync();
			Snackbar.Add(outcome switch
			{
				DataKeyRotationOutcome.Rotated => "새 데이터 키 세대를 발급했습니다.",
				DataKeyRotationOutcome.NoGenerationsYet => "아직 발급된 자격증명이 없어 로테이션할 대상이 없습니다.",
				_ => "로테이션을 완료했습니다.",
			}, outcome == DataKeyRotationOutcome.Rotated ? Severity.Success : Severity.Info);
		}
		catch (Exception ex)
		{
			Snackbar.Add($"로테이션에 실패했습니다: {ex.Message}", Severity.Error);
		}
		finally
		{
			_rotating = false;
		}
	}
}
