@using System.Text
@using System.Text.Unicode
@using Microsoft.AspNetCore.Components.Forms
@using S3EnvManager.Web.Services
@inject IJSRuntime JsRuntime
@inject ISnackbar Snackbar

<MudDialog>
	<DialogContent>
		@if (!ReadOnly)
		{
			<MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-2">
				<InputFile OnChange="OnFileSelectedAsync" accept=".pem,.crt,.cer,.csr,.der,.pfx,.key,.json,.ini,.txt" />
				<MudText Typo="Typo.caption">
					최대 @(MaxFileSizeBytes / (1024 * 1024))MB - 텍스트 파일은 그대로, 바이너리는 base64로 인코딩해 채웁니다.
				</MudText>
			</MudStack>
			@if (_fileImportError is not null)
			{
				<MudAlert Severity="Severity.Error" Class="mb-2" Dense="true">@_fileImportError</MudAlert>
			}
			else if (_fileImportNote is not null)
			{
				<MudAlert Severity="Severity.Info" Class="mb-2" Dense="true">@_fileImportNote</MudAlert>
			}
		}
		<MudTextField T="string" @bind-Value="_value" Lines="15"
			Variant="Variant.Outlined" ReadOnly="ReadOnly" Style="font-family: monospace; min-width: 480px;" />
		<MudText Typo="Typo.caption" Class="mt-1" style="display: block;">
			@SecretValuePreviewFormatter.Summarize(_value)
		</MudText>
	</DialogContent>
	<DialogActions>
		<MudButton StartIcon="@Icons.Material.Filled.ContentCopy" OnClick="CopyAsync">복사</MudButton>
		@if (ReadOnly)
		{
			<MudButton OnClick="Cancel">닫기</MudButton>
		}
		else
		{
			<MudButton OnClick="Cancel">취소</MudButton>
			<MudButton Color="Color.Primary" OnClick="Submit">적용</MudButton>
		}
	</DialogActions>
</MudDialog>

@code {
	// 번들 전체를 매번 통째로 암호화/복호화·조회하는 구조라 값이 커지면 같은 env의 다른 작업까지
	// 느려진다 - 20MB로 상한.
	private const Int64 MaxFileSizeBytes = 20 * 1024 * 1024;

	[CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = null!;
	[Parameter] public string Value { get; set; } = string.Empty;
	[Parameter] public bool ReadOnly { get; set; }

	private string _value = string.Empty;
	private string? _fileImportError;
	private string? _fileImportNote;

	protected override void OnInitialized() => _value = Value;

	private async Task OnFileSelectedAsync(InputFileChangeEventArgs e)
	{
		_fileImportError = null;
		_fileImportNote = null;

		var file = e.File;
		if (file.Size > MaxFileSizeBytes)
		{
			_fileImportError =
				$"파일이 너무 큽니다({file.Size / (1024 * 1024)}MB) - {MaxFileSizeBytes / (1024 * 1024)}MB 이하만 가져올 수 있습니다.";
			return;
		}

		using var stream = file.OpenReadStream(MaxFileSizeBytes);
		using var buffer = new MemoryStream();
		await stream.CopyToAsync(buffer);
		var bytes = buffer.ToArray();

		// NUL 바이트가 섞인 값은 유효한 UTF-8이어도 텍스트로 취급하지 않는다 - env var로
		// 쓰였을 때 문자열 종료로 오인될 수 있어, der/pfx와 마찬가지로 base64로 인코딩한다.
		if (Utf8.IsValid(bytes) && !bytes.Contains((byte)0))
		{
			_value = Encoding.UTF8.GetString(bytes);
			_fileImportNote = $"'{file.Name}' 텍스트 파일을 그대로 불러왔습니다.";
		}
		else
		{
			_value = Convert.ToBase64String(bytes);
			_fileImportNote = $"'{file.Name}'은(는) 바이너리 파일이라 base64로 인코딩했습니다 - " +
				"이 값을 쓰는 앱에서 디코딩해야 합니다.";
		}
	}

	private void Submit() => MudDialog.Close(DialogResult.Ok(_value));
	private void Cancel() => MudDialog.Close(DialogResult.Cancel());

	private async Task CopyAsync()
	{
		await JsRuntime.InvokeVoidAsync("navigator.clipboard.writeText", _value);
		Snackbar.Add("클립보드에 복사했습니다.", Severity.Success);
	}
}
