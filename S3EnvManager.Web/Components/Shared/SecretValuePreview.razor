@using S3EnvManager.Web.Services
@inject IDialogService DialogService

@if (SecretValuePreviewFormatter.IsLongValue(Value))
{
	<MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1" Class="py-1">
		<MudText Typo="Typo.body2"
			Style="font-family: monospace; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
				max-width: 420px;">
			@SecretValuePreviewFormatter.Summarize(Value)
		</MudText>
		<MudIconButton Icon="@Icons.Material.Filled.OpenInFull" Size="Size.Small" OnClick="OpenEditorAsync"
			title="@(ReadOnly ? "전체 보기" : "펼쳐서 편집")" />
	</MudStack>
}
else if (ReadOnly)
{
	<MudText Typo="Typo.body2" Style="font-family: monospace;">@Value</MudText>
}
else
{
	<MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
		<MudTextField T="string"
			Value="@Value"
			ValueChanged="OnInlineChangedAsync"
			Immediate="true"
			Style="flex: 1;" />
		<MudIconButton Icon="@Icons.Material.Filled.OpenInFull"
			Size="Size.Small"
			OnClick="OpenEditorAsync"
			title="펼쳐서 편집" />
	</MudStack>
}

@code {
	[Parameter] public string Value { get; set; } = string.Empty;
	[Parameter] public EventCallback<string> ValueChanged { get; set; }
	[Parameter] public bool ReadOnly { get; set; }
	[Parameter] public string? Title { get; set; }

	private Task OnInlineChangedAsync(string newValue) => ValueChanged.InvokeAsync(newValue);

	private async Task OpenEditorAsync()
	{
		var parameters = new DialogParameters<SecretValueEditDialog>
		{
			{ x => x.Value, Value },
			{ x => x.ReadOnly, ReadOnly },
		};
		var title = Title ?? (ReadOnly ? "값 보기" : "값 편집");
		var dialog = await DialogService.ShowAsync<SecretValueEditDialog>(title, parameters);
		var result = await dialog.Result;
		if (!ReadOnly && result is { Canceled: false } && result.Data is string newValue)
		{
			await ValueChanged.InvokeAsync(newValue);
		}
	}
}
