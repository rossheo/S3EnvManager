@using S3EnvManager.Web.Services
@inject IJSRuntime JsRuntime
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<MudDialog>
	<DialogContent>
		@if (_loading)
		{
			<MudProgressCircular Color="Color.Default" Indeterminate="true" />
		}
		else if (_versions.Count == 0)
		{
			<MudText Typo="Typo.body2">저장된 버전이 없습니다.</MudText>
		}
		else
		{
			<MudTable Items="_versions" Hover="true" Elevation="0" Style="min-width: 480px;">
				<HeaderContent>
					<MudTh>저장 시각</MudTh>
					<MudTh>작성자</MudTh>
					<MudTh></MudTh>
					<MudTh></MudTh>
				</HeaderContent>
				<RowTemplate>
					<MudTd DataLabel="저장 시각">
						@context.LastModified.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss")
					</MudTd>
					<MudTd DataLabel="작성자">@(context.ActorEmail ?? "-")</MudTd>
					<MudTd>
						@if (context.IsLatest)
						{
							<MudChip T="string" Size="Size.Small" Color="Color.Primary">현재</MudChip>
						}
					</MudTd>
					<MudTd>
						<MudButton Size="Size.Small" Variant="Variant.Text"
							OnClick="@(() => ViewVersionAsync(context.VersionId))">
							내용 보기
						</MudButton>
					</MudTd>
				</RowTemplate>
			</MudTable>

			@if (_selectedVersionId is not null)
			{
				<MudDivider Class="my-3" />
				@if (_valuesLoading)
				{
					<MudProgressCircular Color="Color.Default" Indeterminate="true" />
				}
				else if (_selectedError is not null)
				{
					<MudAlert Severity="Severity.Error">@_selectedError</MudAlert>
				}
				else if (_selectedValues is not null)
				{
					@if (_selectedValues.Count == 0)
					{
						<MudText Typo="Typo.body2">이 버전에는 키가 없습니다.</MudText>
					}
					else
					{
						<MudStack Row="true" Justify="Justify.FlexEnd" Spacing="2" Class="mb-2">
							<MudButton Size="Size.Small" Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.Visibility"
								OnClick="ViewAllSelectedAsync">
								전체 보기
							</MudButton>
							<MudButton Size="Size.Small" Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.ContentCopy"
								OnClick="CopyAllSelectedAsync">
								전체 복사
							</MudButton>
						</MudStack>
						<MudTable Items="_selectedValues" Hover="true" Elevation="0">
							<HeaderContent>
								<MudTh>키</MudTh>
								<MudTh>값</MudTh>
							</HeaderContent>
							<RowTemplate>
								<MudTd DataLabel="키">
									<MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
										<span>@context.Key</span>
										<MudIconButton Icon="@Icons.Material.Filled.ContentCopy" Size="Size.Small"
											OnClick="@(() => CopyToClipboardAsync(context.Key, "키"))" title="키 복사" />
									</MudStack>
								</MudTd>
								<MudTd DataLabel="값">
									<MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
										<SecretValuePreview Value="@context.Value" ReadOnly="true" />
										<MudIconButton Icon="@Icons.Material.Filled.ContentCopy" Size="Size.Small"
											OnClick="@(() => CopyToClipboardAsync(context.Value, "값"))" title="값 복사" />
									</MudStack>
								</MudTd>
							</RowTemplate>
						</MudTable>
					}
				}
			}
		}
	</DialogContent>
	<DialogActions>
		<MudButton OnClick="Close">닫기</MudButton>
	</DialogActions>
</MudDialog>

@code {
	[CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = null!;
	[Parameter] public Guid EnvId { get; set; }
	[Parameter] public SecretBundleKind Kind { get; set; }
	[Parameter] public ISecretBundleService SecretBundleService { get; set; } = null!;

	private bool _loading = true;
	private IReadOnlyList<SecretObjectVersion> _versions = [];
	private string? _selectedVersionId;
	private bool _valuesLoading;
	private IReadOnlyDictionary<string, string>? _selectedValues;
	private string? _selectedError;

	protected override async Task OnInitializedAsync()
	{
		_versions = await SecretBundleService.ListHistoryAsync(EnvId, Kind);
		_loading = false;
	}

	private async Task ViewVersionAsync(string versionId)
	{
		_selectedVersionId = versionId;
		_selectedValues = null;
		_selectedError = null;
		_valuesLoading = true;
		try
		{
			_selectedValues = await SecretBundleService.LoadVersionAsync(EnvId, versionId, Kind);
		}
		catch (Exception ex)
		{
			_selectedError = $"이 버전은 복호화할 수 없습니다(감쌌던 CMK가 제거되었을 수 있습니다): {ex.Message}";
		}
		finally
		{
			_valuesLoading = false;
		}
	}

	private void Close() => MudDialog.Close(DialogResult.Ok(true));

	private async Task CopyToClipboardAsync(string value, string label)
	{
		await JsRuntime.InvokeVoidAsync("navigator.clipboard.writeText", value);
		Snackbar.Add($"{label}을(를) 클립보드에 복사했습니다.", Severity.Success);
	}

	private async Task CopyAllSelectedAsync()
	{
		if (_selectedValues is null)
		{
			return;
		}

		var text = SecretBundleTextFormat.Format(_selectedValues);
		await JsRuntime.InvokeVoidAsync("navigator.clipboard.writeText", text);
		Snackbar.Add("전체 항목을 클립보드에 복사했습니다.", Severity.Success);
	}

	private async Task ViewAllSelectedAsync()
	{
		if (_selectedValues is null)
		{
			return;
		}

		var parameters = new DialogParameters<SecretValueEditDialog>
		{
			{ x => x.Value, SecretBundleTextFormat.Format(_selectedValues) },
			{ x => x.ReadOnly, true },
		};
		await DialogService.ShowAsync<SecretValueEditDialog>("전체 보기", parameters);
	}
}
